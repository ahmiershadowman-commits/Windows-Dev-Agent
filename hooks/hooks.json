{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m src.safety.gate --tool bash --args \"$TOOL_INPUT\"",
            "description": "Safety gate: classify and approve/checkpoint shell commands before execution"
          }
        ]
      },
      {
        "matcher": "mcp__windows-dev-agent__package_install",
        "hooks": [
          {
            "type": "command",
            "command": "python -m src.safety.gate --tool package_install --args \"$TOOL_INPUT\"",
            "description": "Require explicit approval before any WinGet install"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m src.observability.trace --event post_tool --input \"$TOOL_INPUT\" --output \"$TOOL_OUTPUT\"",
            "description": "Emit OpenTelemetry trace for every tool use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m src.observability.audit_report",
            "description": "Generate self-audit report at end of session"
          }
        ]
      }
    ]
  }
}
